<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/quick_book_title"
            android:textColor="@color/text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/quick_book_help"
            android:textColor="@color/text_muted"
            android:textSize="13sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_pick_date_today"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputQuickDate"
                style="@style/SelectTimeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:focusable="false"
                android:hint="@string/hint_use_date"
                android:clickable="true" />

            <TextView
                android:id="@+id/textQuickTodayNow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/accent"
                android:textSize="13sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_pick_time"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputQuickTime"
                style="@style/SelectTimeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:focusable="false"
                android:hint="@string/hint_pick_time"
                android:clickable="true" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/label_courts"
                android:textColor="@color/text_muted"
                android:textSize="13sp" />

            <EditText
                android:id="@+id/inputQuickCourt"
                style="@style/SelectTimeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="false"
                android:hint="@string/hint_courts" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/quick_book_notice"
                android:textColor="@color/warn"
                android:textSize="12sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnQuickStart"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/accent"
            android:text="@string/quick_book_start"
            android:textColor="@color/bg"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
