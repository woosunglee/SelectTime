<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.SelectTime" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/bg</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:textColorPrimary">@color/text</item>
        <item name="android:textColorSecondary">@color/text_muted</item>
    </style>

    <!-- Light dialog: dark day numbers + visible action buttons. -->
    <style name="Theme.SelectTime.DatePicker" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/picker_day</item>
        <item name="android:textColorSecondary">@color/picker_day_muted</item>
        <item name="android:windowBackground">@color/picker_bg</item>
        <item name="buttonBarPositiveButtonStyle">@style/SelectTime.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/SelectTime.DialogButton</item>
    </style>

    <!-- Light list dialog: dark text on white (readable card/payment pickers). -->
    <style name="Theme.SelectTime.ListDialog" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:textColorPrimary">@color/picker_day</item>
        <item name="android:textColorSecondary">@color/picker_day_muted</item>
        <item name="android:windowBackground">@color/picker_bg</item>
        <item name="android:background">@color/picker_bg</item>
        <item name="buttonBarPositiveButtonStyle">@style/SelectTime.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/SelectTime.DialogButton</item>
    </style>

    <style name="SelectTime.DialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SelectTimeInput">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/text</item>
        <item name="android:textColorHint">@color/text_muted</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="SelectTimeDayChip">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">13sp</item>
        <item name="android:background">@drawable/bg_day_chip</item>
        <item name="android:textColor">@color/text</item>
    </style>
</resources>
